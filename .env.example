# ========== SAKI ENVIRONMENT VARIABLES ==========
# Copy file ini ke .env dan isi dengan nilai Anda

# Security
ADMIN_PASSWORD=saki2024

# AI Model (lihat di: ollama pull <model>)
MODEL=qwen3:4b

# Ollama Configuration
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Database
DB_PATH=saki_memory.db

# Folders
DOCUMENTS_FOLDER=documents
CHROMA_FOLDER=chroma_db
EXPORT_FOLDER=exports
SAVE_FOLDER=ringkasan

# Thresholds
AUTO_EXTRACT_THRESHOLD=0.7

# Logging
LOG_LEVEL=INFO
LOG_FILE=saki.log

# Optional: PostgreSQL untuk production
# DB_TYPE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=saki_memory
# DB_USER=saki
# DB_PASSWORD=your_secure_password
